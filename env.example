# Mock Server Configuration
# This file contains environment variables for the mock server
# Copy this to .env and modify as needed

# Message Selection Configuration
MOCK_SERVER_DEFAULT_MESSAGE_COUNT=10
MOCK_SERVER_MAX_MESSAGE_COUNT=1000
MOCK_SERVER_MIN_MESSAGE_COUNT=1

# Distribution Configuration
MOCK_SERVER_DEFAULT_DISTRIBUTION_FIELD=senderEmail
MOCK_SERVER_DEFAULT_DISTRIBUTION_TYPE=uniform

# Data Configuration
MOCK_SERVER_DATA_FILE_PATH=./datasets/truth_data.json
MOCK_SERVER_SAMPLE_DATA_COUNT=100

# Server Configuration
MOCK_SERVER_HOST=0.0.0.0
MOCK_SERVER_PORT=8080

# Logging Configuration
MOCK_SERVER_ENABLE_DEBUG_LOGGING=false
